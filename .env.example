# ── Required: at least one LLM provider key ─────────────────────────────────

# Recommended: OpenRouter (access to all models via one key)
OPENROUTER_API_KEY=sk-or-...
LLM_MODEL=openai/gpt-4o-mini

# Or: direct OpenAI
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# Or: direct Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=claude-sonnet-4-5

# ── Optional: Tool APIs ──────────────────────────────────────────────────────

# Web search (pick one or more)
EXA_API_KEY=
FIRECRAWL_API_KEY=
PARALLEL_API_KEY=

# Image generation
FAL_KEY=

# Cross-session user modeling
HONCHO_API_KEY=

# GitHub (higher rate limits for code tools)
GITHUB_TOKEN=

# ── Optional: Browser automation ─────────────────────────────────────────────
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# ── Gateway security ──────────────────────────────────────────────────────────
# Set to false and configure allowlists if you want to restrict access
GATEWAY_ALLOW_ALL_USERS=true

# ── Terminal backend ──────────────────────────────────────────────────────────
# Options: local, docker, modal, ssh
TERMINAL_ENV=local
TERMINAL_TIMEOUT=60

# ── GenUI artifact portal ─────────────────────────────────────────────────────
# Stores structured UI artifacts at /data/genui/artifacts and serves them at
# /ui/latest/{id}, /ui/saved, /ui/daily. GBrain (or any caller) POSTs to
# /api/ui/artifacts. Set GENUI_API_TOKEN to allow same-container server-to-
# server posting without a browser cookie session.
GENUI_ENABLED=true
# GENUI_BASE_URL=https://your-app.up.railway.app
GENUI_STORAGE=/data/genui
GENUI_TEMPORARY_TTL_HOURS=72
GENUI_AUTO_SAVE_CATEGORIES=daily_briefing,portfolio,jobs
# GENUI_API_TOKEN=<random-32+-char-secret>

# ── GBrain (Dbrain fork) ──────────────────────────────────────────────────────
# When enabled, start.sh clones/updates GBRAIN_REPO_URL@GBRAIN_REF into
# GBRAIN_DIR on the persistent volume, then runs `bun install` + `bun link`
# so the `gbrain` CLI is available to Hermes. If GBRAIN_REQUIRED=false,
# install failures only warn and Hermes still starts.
GBRAIN_ENABLED=false
GBRAIN_REPO_URL=https://github.com/dforwardfeed/Dbrain-hermes.git
GBRAIN_REF=main
GBRAIN_DIR=/data/gbrain
GBRAIN_REQUIRED=false
